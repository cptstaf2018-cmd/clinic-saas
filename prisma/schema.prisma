generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Clinic {
  id                      String         @id @default(cuid())
  name                    String
  whatsappNumber          String         @unique
  logoUrl                 String?
  botEnabled              Boolean        @default(true)
  whatsappPhoneNumberId   String?
  whatsappAccessToken     String?
  whatsappWelcomeMessage  String?
  createdAt               DateTime       @default(now())
  users             User[]
  patients          Patient[]
  appointments      Appointment[]
  payments          Payment[]
  workingHours      WorkingHours[]
  subscription      Subscription?
  incomingMessages  IncomingMessage[]
}

model User {
  id           String   @id @default(cuid())
  clinicId     String?
  clinic       Clinic?  @relation(fields: [clinicId], references: [id])
  email        String?  @unique
  passwordHash String
  role         String   @default("doctor") // doctor | staff | superadmin
  createdAt    DateTime @default(now())
}

model OtpCode {
  id        String   @id @default(cuid())
  phone     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([phone])
}

model InvitationCode {
  id        String    @id @default(cuid())
  code      String    @unique
  note      String?
  used      Boolean   @default(false)
  usedAt    DateTime?
  clinicId  String?
  createdAt DateTime  @default(now())

  @@index([code])
}

model Subscription {
  id        String   @id @default(cuid())
  clinicId  String   @unique
  clinic    Clinic   @relation(fields: [clinicId], references: [id])
  plan      String   @default("trial") // trial | basic | standard | premium
  status    String   @default("trial") // trial | active | inactive
  startDate DateTime @default(now())
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Patient {
  id            String        @id @default(cuid())
  clinicId      String
  clinic        Clinic        @relation(fields: [clinicId], references: [id])
  name          String
  whatsappPhone String
  createdAt     DateTime      @default(now())
  appointments  Appointment[]

  @@unique([clinicId, whatsappPhone])
  @@index([clinicId])
}

model Appointment {
  id              String   @id @default(cuid())
  clinicId        String
  clinic          Clinic   @relation(fields: [clinicId], references: [id])
  patientId       String
  patient         Patient  @relation(fields: [patientId], references: [id])
  date            DateTime
  status          String   @default("pending") // pending | confirmed | completed | cancelled
  queueNumber     Int?
  queueStatus     String   @default("waiting") // waiting | current | done
  reminder24hSent Boolean  @default(false)
  reminder1hSent  Boolean  @default(false)
  createdAt       DateTime @default(now())

  @@index([clinicId])
  @@index([clinicId, date])
  @@index([clinicId, status])
}

model WorkingHours {
  id        String  @id @default(cuid())
  clinicId  String
  clinic    Clinic  @relation(fields: [clinicId], references: [id])
  dayOfWeek Int
  startTime String
  endTime   String
  isOpen    Boolean @default(true)

  @@unique([clinicId, dayOfWeek])
  @@index([clinicId])
}

model WhatsappSession {
  id        String   @id @default(cuid())
  clinicId  String
  phone     String
  step      String
  updatedAt DateTime @updatedAt

  @@unique([clinicId, phone])
  @@index([clinicId])
}

model IncomingMessage {
  id        String   @id @default(cuid())
  clinicId  String
  clinic    Clinic   @relation(fields: [clinicId], references: [id])
  phone     String
  body      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([clinicId])
  @@index([clinicId, read])
}

model Payment {
  id        String   @id @default(cuid())
  clinicId  String
  clinic    Clinic   @relation(fields: [clinicId], references: [id])
  amount    Int
  method    String
  status    String   @default("pending")
  reference String?
  createdAt DateTime @default(now())

  @@index([clinicId])
  @@index([status])
}

model PlatformSettings {
  id      String  @id @default("singleton")
  logoUrl String?
}
